# ═══════════════════════════════════════════════════════════
# COGIT CLI - Configuration File
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys
# At least one AI provider is required for the CLI to work
# ═══════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────
# AI PROVIDER SELECTION
# ───────────────────────────────────────────────────────────
# Options: auto | groq | openrouter | openai | gemini | ollama
# - auto: Automatically selects first available provider (recommended)
# - groq: Fast inference with Llama models
# - openrouter: Access to 100+ models via proxy
# - openai: OpenAI GPT models
# - gemini: Google Gemini models
# - ollama: Local models (no API key needed)
AI_PROVIDER=auto

# ───────────────────────────────────────────────────────────
# LANGUAGE SETTINGS
# ───────────────────────────────────────────────────────────
# Options: en | pt
# LANGUAGE: Interface language (menus, messages, errors)
# COMMIT_LANGUAGE: Language for commit messages generated by AI
LANGUAGE=en
COMMIT_LANGUAGE=en

# ───────────────────────────────────────────────────────────
# API KEYS
# ───────────────────────────────────────────────────────────
# Get your keys at:
# - Groq: https://console.groq.com/keys
# - OpenRouter: https://openrouter.ai/keys
# - OpenAI: https://platform.openai.com/api-keys
# - Gemini: https://aistudio.google.com/app/apikey
# - Ollama: No key needed (runs locally at http://localhost:11434)

OPENROUTER_API_KEY=your_openrouter_key_here
GROQ_API_KEY=your_groq_key_here
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here

# ───────────────────────────────────────────────────────────
# AI MODELS (Optional - defaults are optimized for speed/cost)
# ───────────────────────────────────────────────────────────
# Groq models: llama-4-scout-17b-16e-instruct (fast), llama-3.3-70b-versatile
# OpenRouter models: meta-llama/llama-4-scout, google/gemma-3-27b-it
# OpenAI models: gpt-4o-mini (fast/cheap), gpt-4o, gpt-4-turbo
# Gemini models: gemini-pro, gemini-1.5-flash, gemini-1.5-pro
# Ollama models: llama3, mistral, codellama (any local model)

OPENROUTER_MODEL=meta-llama/llama-4-scout
GROQ_MODEL=llama-4-scout-17b-16e-instruct
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-pro
OLLAMA_MODEL=llama3
