{
  "name": "cogit-cli",
  "version": "0.1.0",
  "description": "Git automation CLI with AI-powered commit messages and auto push",
  "main": "dist/index.js",
  "bin": {
    "cogit": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "dev": "ts-node src/index.ts",
    "test": "npm run test:platform && npm run test:all",
    "test:platform": "node test-automation/platform/platform-test.js",
    "test:all": "node test-automation/test-all-fases.js",
    "test:unit": "node test-automation/unit/run-unit-tests.js"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "inquirer": "^9.2.0",
    "dotenv": "^16.4.0",
    "openai": "^4.0.0",
    "@google/generative-ai": "^0.21.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/inquirer": "^9.0.0",
    "ts-node": "^10.9.0"
  }
}
